# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret
POSTGRES_DB=personal_agent_db
DATABASE_URL=postgresql://agent:agent_secret@localhost:5432/personal_agent_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_to_a_long_random_string
CORS_ORIGIN=http://localhost:5173

# ─── Anthropic / Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Calendar OAuth2 ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# ─── OpenClaw ─────────────────────────────────────────────────────────────────
OPENCLAW_HOOKS_TOKEN=changeme
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_DEFAULT_CHANNEL=telegram

# ─── PDF ──────────────────────────────────────────────────────────────────────
PDF_MAX_SIZE_MB=25
PDF_RETENTION_DAYS=90
UPLOAD_DIR=/app/uploads
